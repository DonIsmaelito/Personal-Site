---
interface Entry {
  title: string;
  href?: string;
  meta?: string;
  description?: string;
  details?: string[];
}

interface Props {
  title: string;
  entries: Entry[];
  /**
   * When true the section is a column inside the page grid: it suppresses its
   * own top hairline so the band draws ONE rule above the whole grid (mirrors
   * the .intro band). Used stand-alone (default false) it keeps its own
   * hairline, so the component stays reusable as a stacked section elsewhere.
   */
  inGrid?: boolean;
}

const { title, entries, inGrid = false } = Astro.props;

// Site-relative hrefs render plainly; absolute (http/https) hrefs open in a
// new tab with safe rel attributes AND get a decorative external-link arrow.
const isExternal = (href?: string): boolean =>
  !!href && /^https?:\/\//.test(href);
---

<section class="section" class:list={{ 'in-grid': inGrid }}>
  <h2 class="section-heading">{title}</h2>

  <ul class="entries" role="list">
    {
      entries.map((entry) => (
        <li class="entry">
          <div class="entry-head">
            {entry.href ? (
              <a
                class:list={[
                  'entry-title',
                  { 'is-external': isExternal(entry.href) },
                ]}
                href={entry.href}
                {...(isExternal(entry.href)
                  ? { target: '_blank', rel: 'noopener noreferrer' }
                  : {})}
              >
                <span class="entry-title-text">{entry.title}</span>
              </a>
            ) : (
              <span class="entry-title">{entry.title}</span>
            )}
            {entry.meta && <span class="entry-meta">{entry.meta}</span>}
          </div>
          {entry.description && <p class="entry-desc">{entry.description}</p>}
          {entry.details && (
            <ul class="entry-details">
              {entry.details.map((detail) => <li>{detail}</li>)}
            </ul>
          )}
        </li>
      ))
    }
  </ul>
</section>

<style>
  /* Per-section top hairline. Suppressed by `in-grid` so the page band draws a
     single rule above the whole grid (mirrors .intro) and the columns stay
     borderless and top-aligned. */
  .section {
    border-top: 1px solid var(--border);
    padding-top: 2.5rem;
    min-width: 0;
  }

  .section.in-grid {
    border-top: 0;
    padding-top: 0;
  }

  /* The section heading (.section-heading) is a shared rule in global.css,
     used here and in ExperienceSection.astro so both columns match the h1. */

  .entries {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 1.75rem;
  }

  .entry {
    margin: 0;
  }

  .entry-head {
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
  }

  .entry-title {
    font-size: 1.125rem;
    line-height: 1.4;
    min-width: 0;
    overflow-wrap: anywhere;
  }

  span.entry-title {
    color: var(--text);
  }

  /* The global `a` rule puts the underline on the anchor box. To keep the
     decorative arrow un-underlined (paco fidelity), we move the underline onto
     the inner text span and strip it from the anchor itself. The link colour
     and hover-fill behaviour are inherited from the global `a` / `a:hover`
     rules; we only relocate the border. */
  a.entry-title {
    border-bottom: none;
  }

  .entry-title-text {
    border-bottom: 1px solid color-mix(in srgb, var(--link) 35%, transparent);
    transition: border-color 0.15s ease;
  }

  a.entry-title:hover .entry-title-text {
    border-bottom-color: var(--link);
  }

  a.entry-title:focus-visible {
    outline: 2px solid var(--link);
    outline-offset: 3px;
    border-radius: 2px;
  }

  /* paco external-link marker: a decorative "↗" appended ONLY to external
     links, as pseudo-content so it is never part of the accessible name. The
     leading NBSP tethers it to the title's last word (and the inline-block +
     nowrap keep it from orphan-wrapping onto its own line). It sits OUTSIDE
     the underlined text span, so the link underline stays on the words only —
     the arrow is dim mono, matching paco's un-underlined icon. */
  a.entry-title.is-external::after {
    content: '\00A0\2197'; /* NBSP + NORTH EAST ARROW */
    display: inline-block;
    white-space: nowrap;
    font-family: var(--font-mono);
    font-size: 0.85em;
    line-height: 1;
    color: var(--text-muted);
    border-bottom: none;
  }

  .entry-meta {
    margin-left: auto;
    flex-shrink: 0;
    font-family: var(--font-mono);
    font-size: 0.8rem;
    letter-spacing: 0.02em;
    color: var(--text-muted);
    font-variant-numeric: tabular-nums;
    white-space: nowrap;
  }

  .entry-desc {
    margin: 0.4rem 0 0;
    max-width: 56ch;
    font-size: 1rem;
    line-height: 1.5;
    color: var(--text-muted);
  }

  .entry-details {
    margin: 0.65rem 0 0;
    padding: 0;
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
    font-size: 0.95rem;
    line-height: 1.5;
    color: var(--text-muted);
  }

  .entry-details li {
    position: relative;
    padding-left: 1rem;
  }

  .entry-details li::before {
    content: '·';
    position: absolute;
    left: 0;
  }

  @media (max-width: 30rem) {
    .entry-head {
      flex-wrap: wrap;
    }

    .entry-meta {
      margin-left: 0;
      flex-basis: 100%;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .entry-title-text {
      transition: none;
    }
  }
</style>
